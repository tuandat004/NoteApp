<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayoutDetail"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/txtBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="‹ Back"
                android:textColor="@color/text_secondary_app"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtHeaderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text=""
                android:textColor="@color/text_primary_app"
                android:textSize="20sp"
                android:visibility="gone"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:orientation="horizontal">
                
                <Button
                    android:id="@+id/btnExportPdf"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_input"
                    android:text="PDF"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary_app" />

                <Button
                    android:id="@+id/btnDelete"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_btn_yellow"
                    android:text="Xóa"
                    android:textAllCaps="false"
                    android:textColor="@color/btn_delete_text" />

                <Button
                    android:id="@+id/btnEdit"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_btn_yellow"
                    android:text="Edit"
                    android:textAllCaps="false"
                    android:textColor="@color/btn_yellow_text" />
            </LinearLayout>
        </RelativeLayout>

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text=""
            android:textColor="@color/text_primary_app"
            android:textSize="30sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtTags"
                style="@style/TagChipYellow"
                android:text="" />

            <TextView
                android:id="@+id/txtCreatedAt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text=""
                android:textColor="@color/text_secondary_app"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_link_chip"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:text=""
            android:textColor="#7C8DA5"
            android:textSize="12sp" />

        <ImageView
            android:id="@+id/imgNote"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_image_thumb"
            android:scaleType="centerCrop" />

        <WebView
            android:id="@+id/webViewContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="#00000000" />

        <TextView
            android:id="@+id/txtReminder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_reminder_box"
            android:padding="14dp"
            android:text=""
            android:textColor="#7B6747"
            android:textSize="15sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/txtLink"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:padding="8dp"
            android:text=""
            android:textColor="@color/text_primary_app"
            android:textColorLink="#2074D4"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>