<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_app">

    <!-- Header: Cancel / Title / Save -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingVertical="14dp"
        android:background="@color/bg_app"
        android:elevation="2dp">

        <TextView
            android:id="@+id/txtCancel"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="Hủy"
            android:textColor="@color/text_secondary_app"
            android:textSize="15sp"
            android:background="?attr/selectableItemBackground"/>

        <TextView
            android:id="@+id/txtHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Tạo Ghi Chú"
            android:textColor="@color/text_primary_app"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_btn_yellow"
            android:paddingHorizontal="20dp"
            android:text="Lưu"
            android:textAllCaps="false"
            android:textColor="@color/btn_yellow_text"
            android:textSize="15sp"
            android:textStyle="bold"/>
    </RelativeLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp">

            <EditText
                android:id="@+id/edtTitle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="Tiêu đề ghi chú..."
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_primary_app"
                android:textColorHint="@color/text_secondary_app"
                android:textSize="17sp"
                android:inputType="textCapSentences"/>

            <EditText
                android:id="@+id/edtSubtitle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:hint="Phụ đề (tuỳ chọn)..."
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_primary_app"
                android:textColorHint="@color/text_secondary_app"
                android:textSize="15sp"
                android:inputType="textCapSentences"/>

            <!-- RichEditor content -->
            <jp.wasabeef.richeditor.RichEditor
                android:id="@+id/editor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="300dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:padding="14dp"/>

            <!-- ─── Action Buttons Panel ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical"
                android:background="@drawable/bg_input"
                android:padding="14dp">

                <!-- Section label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="THÊM VÀO GHI CHÚ"
                    android:textColor="@color/text_secondary_app"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp"/>

                <!-- Row 1: Remind + Add Image -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvRemindMe"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:background="@drawable/bg_action_chip"
                        android:text="🔔 Nhắc nhở"
                        android:textColor="@color/text_secondary_app"
                        android:textSize="14sp"
                        android:drawablePadding="4dp"/>

                    <TextView
                        android:id="@+id/tvAddImage"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:gravity="center"
                        android:background="@drawable/bg_action_chip"
                        android:text="🖼 Thêm ảnh"
                        android:textColor="@color/text_secondary_app"
                        android:textSize="14sp"/>
                </LinearLayout>

                <!-- Row 2: Insert Link + Note Color -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvInsertLink"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:background="@drawable/bg_action_chip"
                        android:text="🔗 Thêm link"
                        android:textColor="@color/text_secondary_app"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/tvNoteColor"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:gravity="center"
                        android:background="@drawable/bg_action_chip"
                        android:text="🎨 Màu nền"
                        android:textColor="@color/text_secondary_app"
                        android:textSize="14sp"/>
                </LinearLayout>

                <!-- Row 3: Ghi âm + Giọng nói -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvRecordAudio"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:background="@drawable/bg_action_chip"
                        android:text="🎙 Ghi âm"
                        android:textColor="@color/text_secondary_app"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/tvVoiceInput"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:gravity="center"
                        android:background="@drawable/bg_action_chip"
                        android:text="🎤 Giọng nói"
                        android:textColor="@color/text_secondary_app"
                        android:textSize="14sp"/>
                </LinearLayout>

                <!-- Color picker panel -->
                <HorizontalScrollView
                    android:id="@+id/layoutColorPicker"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="10dp"
                    android:background="@color/bg_input_app"
                    android:scrollbars="none"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp"
                        android:gravity="center_vertical">

                        <View android:id="@+id/colorDefault" style="@style/ColorCircle" android:background="@color/bg_app"/>
                        <View android:id="@+id/colorYellow" style="@style/ColorCircle" android:background="#F3D986"/>
                        <View android:id="@+id/colorGreen" style="@style/ColorCircle" android:background="#DDE0A8"/>
                        <View android:id="@+id/colorCyan" style="@style/ColorCircle" android:background="#B7D6C6"/>
                        <View android:id="@+id/colorBlue" style="@style/ColorCircle" android:background="#B5C7DE"/>
                        <View android:id="@+id/colorPurple" style="@style/ColorCircle" android:background="#D5C9E3"/>
                        <View android:id="@+id/colorPink" style="@style/ColorCircle" android:background="#EDC9CF"/>
                        <View android:id="@+id/colorOrange" style="@style/ColorCircle" android:background="#F5C9A0"/>
                        <View android:id="@+id/colorGray" style="@style/ColorCircle" android:background="#D9D5D2"/>
                        <View android:id="@+id/colorBlack" style="@style/ColorCircle" android:background="@color/text_primary_app"/>
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Links container -->
                <LinearLayout
                    android:id="@+id/layoutLinksContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>

            <!-- ─── Tags ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical"
                android:background="@drawable/bg_input"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🏷 Tags"
                        android:textColor="@color/text_primary_app"
                        android:textStyle="bold"
                        android:textSize="15sp"/>

                    <Button
                        android:id="@+id/btnAddTag"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_btn_yellow"
                        android:text="+ Chọn / Tạo Tag"
                        android:textAllCaps="false"
                        android:textColor="@color/btn_yellow_text"
                        android:textSize="13sp"
                        android:paddingHorizontal="14dp"/>
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/layoutTagsContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"/>
                </HorizontalScrollView>
            </LinearLayout>

            <!-- Image preview (hidden by default) -->
            <RelativeLayout
                android:id="@+id/layoutImagePreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/imgPreview"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_image_thumb"/>

                <TextView
                    android:id="@+id/btnRemoveImage"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_toEndOf="@id/imgPreview"
                    android:layout_alignTop="@id/imgPreview"
                    android:layout_marginStart="-11dp"
                    android:layout_marginTop="-8dp"
                    android:background="#CC333333"
                    android:text="✕"
                    android:textColor="@color/bg_app"
                    android:textSize="12sp"
                    android:gravity="center"/>

                <TextView
                    android:id="@+id/txtImageName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/imgPreview"
                    android:layout_alignBottom="@id/imgPreview"
                    android:layout_alignParentEnd="true"
                    android:layout_marginStart="12dp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:text="image.png"
                    android:textColor="@color/text_secondary_app"
                    android:textSize="13sp"/>
            </RelativeLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ─── Formatting Toolbar ─── -->
    <LinearLayout
        android:id="@+id/layoutFormattingToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_app"
        android:elevation="10dp"
        android:visibility="gone">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/bg_app"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp">

                <TextView
                    android:id="@+id/btnBold"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="B"
                    android:textColor="@color/text_secondary_app"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

                <TextView
                    android:id="@+id/btnItalic"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="I"
                    android:textColor="@color/text_secondary_app"
                    android:textSize="20sp"
                    android:textStyle="italic"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

                <TextView
                    android:id="@+id/btnUnderline"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="U"
                    android:textColor="@color/text_secondary_app"
                    android:textSize="20sp"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

                <View
                    android:layout_width="1dp"
                    android:layout_height="28dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="@color/color_divider"/>

                <TextView
                    android:id="@+id/btnBullets"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="•≡"
                    android:textColor="@color/text_secondary_app"
                    android:textSize="18sp"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

                <TextView
                    android:id="@+id/btnChecklist"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="☑"
                    android:textColor="@color/text_secondary_app"
                    android:textSize="18sp"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

                <View
                    android:layout_width="1dp"
                    android:layout_height="28dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="@color/color_divider"/>

                <TextView
                    android:id="@+id/btnTextSize"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:paddingHorizontal="10dp"
                    android:text="Aa"
                    android:textColor="@color/text_secondary_app"
                    android:textSize="17sp"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

                <TextView
                    android:id="@+id/btnAlign"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:paddingHorizontal="10dp"
                    android:text="≡"
                    android:textColor="@color/text_secondary_app"
                    android:textSize="20sp"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

                <TextView
                    android:id="@+id/btnTable"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:paddingHorizontal="10dp"
                    android:text="⊞"
                    android:textColor="@color/text_secondary_app"
                    android:textSize="20sp"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

                <View
                    android:layout_width="1dp"
                    android:layout_height="28dp"
                    android:layout_marginHorizontal="4dp"
                    android:background="@color/color_divider"/>

                <TextView
                    android:id="@+id/btnHideToolbar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="⌨"
                    android:textColor="@color/text_secondary_app"
                    android:textSize="20sp"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

</LinearLayout>
