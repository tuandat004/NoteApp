<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="1dp"
    app:strokeColor="#EEE5DE"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFDFC"
        android:orientation="horizontal"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/txtTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Project Meeting"
                    android:textColor="#2E2A27"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txtTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="Just now"
                    android:textColor="#8C847D"
                    android:textSize="12sp"/>
            </RelativeLayout>

            <TextView
                style="@style/TagChipYellow"
                android:layout_marginTop="8dp"
                android:text="Work"/>

            <TextView
                android:id="@+id/txtContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="Discussed project milestones and upcoming tasks..."
                android:textColor="#5E5751"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/txtLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_link_chip"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:text="dailyplanner.com"
                android:textColor="#7C8DA5"
                android:textSize="12sp"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/imgThumb"
            android:layout_width="78dp"
            android:layout_height="78dp"
            android:layout_marginStart="12dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"
            android:background="@drawable/bg_image_thumb"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>