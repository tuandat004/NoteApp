<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:layout_marginHorizontal="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/color_divider"
    app:strokeWidth="1dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="80dp">

        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingStart="16dp"
            android:paddingBottom="16dp"
            android:paddingEnd="110dp">

            <TextView
                android:id="@+id/txtTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Project Meeting"
                android:textColor="@color/text_primary_app"
                android:textSize="18sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/txtContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:maxLines="3"
                android:ellipsize="end"
                android:text="Discussed project milestones and upcoming tasks..."
                android:textColor="@color/text_secondary_app"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/txtLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_link_chip"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="dailyplanner.com"
                android:textColor="#7C8DA5"
                android:textSize="12sp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Thời gian: trên cùng bên phải -->
        <TextView
            android:id="@+id/txtTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:text="Vừa xong"
            android:textColor="#5E5751"
            android:textSize="12sp"
            android:gravity="end"/>

        <!-- Icon khóa: hiện khi ghi chú bị khóa -->
        <TextView
            android:id="@+id/imgLockIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            android:text="🔒"
            android:textSize="16sp"
            android:visibility="gone"/>

        <!-- Góc dưới phải: Ảnh thumbnail -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="36dp">

            <ImageView
                android:id="@+id/imgThumb"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_image_thumb"
                android:visibility="gone"/>
        </LinearLayout>

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>