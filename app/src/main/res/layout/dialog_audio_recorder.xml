<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_manage_tag_box"
    android:padding="26dp"
    android:gravity="center_horizontal">

    <!-- Status Header -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <View
            android:id="@+id/recordingDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_circle_avatar"
            android:backgroundTint="@color/error"
            android:layout_marginEnd="8dp"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/tvRecordStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sẵn sàng"
            android:textColor="@color/text_primary_app"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvRecordTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="@color/text_primary_app"
        android:textSize="36sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <!-- Waveform Area -->
    <LinearLayout
        android:id="@+id/layoutWaveform"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- Controls -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:id="@+id/btnMainRecord"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_btn_yellow_round"
            android:layout_centerInParent="true"
            android:gravity="center">
            <TextView
                android:id="@+id/tvMainRecordIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎙️"
                android:textSize="32sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnPauseRecord"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_circle_avatar"
            android:gravity="center"
            android:layout_toStartOf="@id/btnMainRecord"
            android:layout_centerVertical="true"
            android:layout_marginEnd="20dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/tvPauseIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏸"
                android:textSize="24sp" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Bottom Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btnCancelRecord"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hủy"
            android:textColor="@color/text_secondary_app"
            android:background="@drawable/bg_input"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/btnReRecord"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ghi lại"
            android:textColor="@color/text_primary_app"
            android:background="@drawable/bg_input"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginEnd="6dp"
            android:layout_marginStart="6dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btnConfirmRecord"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Xong"
            android:textColor="@color/btn_yellow_text"
            android:background="@drawable/bg_btn_yellow"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginStart="6dp"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
